APP_NAME="LinkedIn Gmail Jobs Hub"
APP_ENV=development
API_V1_STR=/api/v1
API_KEY=change-me
DB_URL=sqlite:///./data/jobs_hub.db
GOOGLE_TOKEN_FILE=./secrets/token.json
GOOGLE_CREDENTIALS_FILE=./secrets/credentials.json
GMAIL_QUERY=
GMAIL_LABEL=linkedin_jobs
GMAIL_SENDER_FILTERS=jobs-listings@linkedin.com,jobs-noreply@linkedin.com,jobalerts-noreply@linkedin.com,linkedin@e.linkedin.com,jobs-listings@e.linkedin.com
ALLOWED_SENDER_CONTAINS=linkedin.com
GMAIL_SUBJECT_TERMS=vaga,vagas,job,jobs,oportunidade,oportunidades,candidate-se,candidatura,salvou,salvas
GMAIL_NEWER_THAN_DAYS=7
GMAIL_MAX_RESULTS=50
GMAIL_USER_ID=me
DEFAULT_LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=3
ENABLE_GMAIL_SYNC=true
ENABLE_BROAD_LINKEDIN_FALLBACK=true
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=1.0
RETRY_JITTER_SECONDS=0.25
