# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment and secrets
.env
.env.*
!.env.example
secrets/*
!secrets/.gitkeep
*.pem
*.key
*.crt

# Explicit OAuth credential/token files
credentials.json
token.json
client_secret*.json

# Local databases and runtime files
data/
*.db
*.sqlite
*.sqlite3
*.log

# Ignora todos os artefatos gerados e logs
logs/*

# (Opcional) Mantém a estrutura da pasta no repositório, caso outra pessoa clone o projeto
!logs/.gitkeep

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.cache/

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

logs/*.log
!logs/.gitkeep
exports/
README_estrutura_final.txt
